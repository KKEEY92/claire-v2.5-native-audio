VITE_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
VITE_LIVEKIT_TOKEN_ENDPOINT=https://your-cloud-run-url/token
VITE_BACKEND_URL=https://your-cloud-run-url

# ── LLM-Provider-Switch (agent.py) ────────────────────────────────────────────
# "google" = Cloud-Claire (Gemini 2.5 Flash) | "lmstudio" = Lokal-Claire
LLM_PROVIDER=google
# Nur relevant bei LLM_PROVIDER=lmstudio:
LMSTUDIO_URL=http://localhost:1234/v1
# Instruct-Modell mit Tool-Support empfohlen (KEIN R1-Reasoning-Distill für Voice):
LMSTUDIO_MODEL=qwen2.5-7b-instruct
