# ── Claire V2.5 Native Audio (Standalone) ─────────────────────────────────────
# Nur für claire.py — kein LiveKit, kein Web-Framework.
# Kopiere als .env:  cp .env.native.example .env

# Gemini API Key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# Modell
CLAIRE_MODEL=gemini-2.5-flash-native-audio-preview

# Stimme: Aoede (weiblich, warm) | Kore (weiblich, jung) | Puck (männlich)
#         Charon (männlich, tief) | Fenrir (männlich, markant)
CLAIRE_VOICE=Aoede

# Google Cloud Projekt (für Memory-Embeddings)
GOOGLE_CLOUD_PROJECT=abstract-robot-466303-p5
GOOGLE_CLOUD_LOCATION=europe-west3
